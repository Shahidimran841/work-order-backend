<!doctype html>
<html>
<head>
  <title>Backups - Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/admin">Work Order Admin</a>
      <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary btn-sm" href="/admin">Dashboard</a>
        <a class="btn btn-outline-success btn-sm" href="/admin/work-orders">Work Orders</a>
        <a class="btn btn-outline-primary btn-sm" href="/admin/technicians">Technicians</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/email-recipients">Email Recipients</a>
        <a class="btn btn-outline-info btn-sm" href="/admin/activity-logs">Activity Logs</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/ppt-settings">PPT Settings</a>
        <form method="POST" action="/admin/logout">
          <button class="btn btn-outline-danger btn-sm">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="mb-0">Backup System</h4>

      <form method="POST" action="/admin/backups/create">
        <button class="btn btn-primary" type="submit">
          Create New Backup
        </button>
      </form>
    </div>

    <% if (message) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <p class="mb-1">
          Backup includes:
        </p>
        <ul class="mb-0">
          <li>SQLite database</li>
          <li>Uploaded work order photos</li>
          <li>Generated PPT reports</li>
        </ul>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white fw-bold">Available Backups</div>
      <div class="card-body">
        <% if (backups.length === 0) { %>
          <p class="text-muted mb-0">No backups created yet.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>File Name</th>
                  <th>Size</th>
                  <th>Created</th>
                  <th>Download</th>
                </tr>
              </thead>

              <tbody>
                <% backups.forEach(function(backup) { %>
                  <tr>
                    <td><%= backup.fileName %></td>
                    <td><%= Math.round(backup.size / 1024) %> KB</td>
                    <td><%= backup.createdAt.toLocaleString() %></td>
                    <td>
                      <a
                        class="btn btn-sm btn-outline-primary"
                        href="/admin/backups/<%= backup.fileName %>/download"
                      >
                        Download
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
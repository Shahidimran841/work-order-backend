<!doctype html>
<html>
<head>
  <title>Admin Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/admin">Work Order Admin</a>
      <div class="d-flex gap-2">
        <a class="btn btn-outline-success btn-sm" href="/admin/work-orders">Work Orders</a>
        <a class="btn btn-outline-primary btn-sm" href="/admin/technicians">Technicians</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/email-recipients">Email Recipients</a>
        <a class="btn btn-outline-info btn-sm" href="/admin/activity-logs">Activity Logs</a>
        <a class="btn btn-outline-warning btn-sm" href="/admin/backups">Backups</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/ppt-settings">PPT Settings</a>
        <form method="POST" action="/admin/logout">
          <button class="btn btn-outline-danger btn-sm">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <h4 class="mb-3">Dashboard</h4>

    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <div class="text-muted">Technicians</div>
            <h3><%= stats.totalTechnicians %></h3>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <div class="text-muted">Pending Approvals</div>
            <h3><%= stats.pendingTechnicians %></h3>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <div class="text-muted">Work Orders</div>
            <h3><%= stats.totalWorkOrders %></h3>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <div class="text-muted">Photos</div>
            <h3><%= stats.totalPhotos %></h3>
          </div>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white fw-bold">Recent Work Orders</div>
      <div class="card-body">
        <% if (recentWorkOrders.length === 0) { %>
          <p class="text-muted mb-0">No work orders uploaded yet.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Work Order</th>
                  <th>Asset ID</th>
                  <th>Technician</th>
                  <th>Photos</th>
                  <th>Status</th>
                  <th>PPT</th>
                </tr>
              </thead>
              <tbody>
                <% recentWorkOrders.forEach(function(order) { %>
                  <tr>
                    <td><%= order.id %></td>
                    <td><%= order.work_order_number %></td>
                    <td><%= order.asset_id %></td>
                    <td>
                      <%= order.technician_name || 'Unknown' %><br />
                      <small class="text-muted"><%= order.technician_phone || '' %></small>
                    </td>
                    <td><%= order.photo_count %></td>
                    <td><span class="badge bg-primary"><%= order.status %></span></td>
                    <td>
                      <span class="badge bg-secondary"><%= order.ppt_status %></span>
                      <br />
                      <a class="btn btn-sm btn-outline-primary mt-1" href="/admin/work-orders/<%= order.id %>">
                        Review
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
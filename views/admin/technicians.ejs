<!doctype html>
<html>
<head>
  <title>Technicians - Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/admin">Work Order Admin</a>
      <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" href="/admin">Dashboard</a>
        <a class="btn btn-outline-success btn-sm" href="/admin/work-orders">Work Orders</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/email-recipients">Email Recipients</a>
        <a class="btn btn-outline-info btn-sm" href="/admin/activity-logs">Activity Logs</a>
        <a class="btn btn-outline-warning btn-sm" href="/admin/backups">Backups</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/ppt-settings">PPT Settings</a>
        <form method="POST" action="/admin/logout">
          <button class="btn btn-outline-danger btn-sm">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <h4 class="mb-3">Technician Management</h4>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <% if (technicians.length === 0) { %>
          <p class="text-muted mb-0">No technicians registered yet.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Phone</th>
                  <th>QID</th>
                  <th>Job Title</th>
                  <th>Status</th>
                  <th>Created</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% technicians.forEach(function(user) { %>
                  <tr>
                    <td><%= user.full_name %></td>
                    <td><%= user.phone %></td>
                    <td><%= user.qid_number || '-' %></td>
                    <td><%= user.job_title || '-' %></td>
                    <td>
                      <% if (user.status === 'approved') { %>
                        <span class="badge bg-success">Approved</span>
                      <% } else if (user.status === 'rejected') { %>
                        <span class="badge bg-danger">Rejected</span>
                      <% } else { %>
                        <span class="badge bg-warning text-dark">Pending</span>
                      <% } %>
                    </td>
                    <td><small><%= user.created_at %></small></td>
                    <td>
                      <div class="d-flex gap-2">
                        <form method="POST" action="/admin/technicians/<%= user.id %>/approve">
                          <button class="btn btn-success btn-sm" type="submit">Approve</button>
                        </form>

                        <form method="POST" action="/admin/technicians/<%= user.id %>/reject">
                          <button class="btn btn-danger btn-sm" type="submit">Reject</button>
                        </form>
                        <form
  method="POST"
  action="/admin/technicians/<%= user.id %>/delete"
  onsubmit="return confirm('Are you sure you want to permanently delete this technician? This will also delete all work orders, photos and PPT reports of this technician.');"
>
  <button class="btn btn-outline-danger btn-sm" type="submit">
    Delete
  </button>
</form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
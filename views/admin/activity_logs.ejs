<!doctype html>
<html>
<head>
  <title>Activity Logs - Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/admin">Work Order Admin</a>
      <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary btn-sm" href="/admin">Dashboard</a>
        <a class="btn btn-outline-success btn-sm" href="/admin/work-orders">Work Orders</a>
        <a class="btn btn-outline-primary btn-sm" href="/admin/technicians">Technicians</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/email-recipients">Email Recipients</a>
        <a class="btn btn-outline-warning btn-sm" href="/admin/backups">Backups</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/ppt-settings">PPT Settings</a>
        <form method="POST" action="/admin/logout">
          <button class="btn btn-outline-danger btn-sm">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <h4 class="mb-3">Activity Logs</h4>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <% if (logs.length === 0) { %>
          <p class="text-muted mb-0">No activity logs yet.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Action</th>
                  <th>User</th>
                  <th>Details</th>
                  <th>Time</th>
                </tr>
              </thead>

              <tbody>
                <% logs.forEach(function(log) { %>
                  <tr>
                    <td><%= log.id %></td>
                    <td><span class="badge bg-primary"><%= log.action %></span></td>
                    <td>
                      <%= log.user_name || 'System' %><br />
                      <small class="text-muted"><%= log.user_phone || '' %></small>
                    </td>
                    <td><small><%= log.details || '-' %></small></td>
                    <td><small><%= log.created_at %></small></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
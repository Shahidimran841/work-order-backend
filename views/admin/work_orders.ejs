<!doctype html>
<html>
<head>
  <title>Work Orders - Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/admin">Work Order Admin</a>
      <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" href="/admin">Dashboard</a>
        <a class="btn btn-outline-primary btn-sm" href="/admin/technicians">Technicians</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/email-recipients">Email Recipients</a>
        <a class="btn btn-outline-info btn-sm" href="/admin/activity-logs">Activity Logs</a>
        <a class="btn btn-outline-warning btn-sm" href="/admin/backups">Backups</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/ppt-settings">PPT Settings</a>
        <form method="POST" action="/admin/logout">
          <button class="btn btn-outline-danger btn-sm">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="mb-0">Work Orders</h4>
      <a href="/admin/work-orders" class="btn btn-sm btn-outline-secondary">Reset Filters</a>
    </div>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body">
        <form class="row g-2" method="GET" action="/admin/work-orders">
          <div class="col-md-4">
            <input
              class="form-control"
              name="search"
              placeholder="Search WO or Asset ID"
              value="<%= filters.search %>"
            />
          </div>

          <div class="col-md-3">
            <select class="form-select" name="status">
              <option value="">All Statuses</option>
              <option value="uploaded" <%= filters.status === 'uploaded' ? 'selected' : '' %>>Uploaded</option>
              <option value="received" <%= filters.status === 'received' ? 'selected' : '' %>>Received</option>
            </select>
          </div>

          <div class="col-md-3">
            <select class="form-select" name="technician">
              <option value="">All Technicians</option>
              <% technicians.forEach(function(tech) { %>
                <option
                  value="<%= tech.id %>"
                  <%= String(filters.technician) === String(tech.id) ? 'selected' : '' %>
                >
                  <%= tech.full_name %> - <%= tech.phone %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="col-md-2">
            <button class="btn btn-primary w-100" type="submit">Filter</button>
          </div>
        </form>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <% if (workOrders.length === 0) { %>
          <p class="text-muted mb-0">No work orders found.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Work Order</th>
                  <th>Asset ID</th>
                  <th>Technician</th>
                  <th>Photos</th>
                  <th>Status</th>
                  <th>PPT</th>
                  <th>Email</th>
                  <th>Received</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% workOrders.forEach(function(order) { %>
                  <tr>
                    <td><%= order.id %></td>
                    <td class="fw-semibold"><%= order.work_order_number %></td>
                    <td><%= order.asset_id || '-' %></td>
                    <td>
                      <%= order.technician_name || 'Unknown' %><br />
                      <small class="text-muted"><%= order.technician_phone || '' %></small>
                    </td>
                    <td><%= order.photo_count %></td>
                    <td><span class="badge bg-primary"><%= order.status %></span></td>
                    <td>
                      <% if (order.ppt_status === 'needs_regeneration') { %>
                        <span class="badge bg-warning text-dark">needs regeneration</span>
                      <% } else { %>
                        <span class="badge bg-secondary"><%= order.ppt_status || 'not_generated' %></span>
                      <% } %>
                      <td>
  <% if (order.email_status === 'sent') { %>
    <span class="badge bg-success">Sent</span>
  <% } else if (order.email_status === 'test_mode') { %>
    <span class="badge bg-info text-dark">Test Mode</span>
  <% } else if (order.email_status === 'failed') { %>
    <span class="badge bg-danger">Failed</span>
  <% } else if (order.email_status === 'sending') { %>
    <span class="badge bg-primary">Sending</span>
  <% } else { %>
    <span class="badge bg-secondary">Not Sent</span>
  <% } %>
</td>
                    </td>
                    <td><small><%= order.received_at || '-' %></small></td>
                    <td>
                      <div class="d-flex gap-2">
  <a class="btn btn-sm btn-primary" href="/admin/work-orders/<%= order.id %>">
    Review
  </a>

  <form
    method="POST"
    action="/admin/work-orders/<%= order.id %>/delete"
    onsubmit="return confirm('Are you sure you want to delete this work order? This will also delete its photos and generated PPT.');"
  >
    <button class="btn btn-sm btn-outline-danger" type="submit">
      Delete
    </button>
  </form>
</div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
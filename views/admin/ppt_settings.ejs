<!doctype html>
<html>
<head>
  <title>PPT Settings - Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/admin">Work Order Admin</a>

      <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary btn-sm" href="/admin">Dashboard</a>
        <a class="btn btn-outline-success btn-sm" href="/admin/work-orders">Work Orders</a>
        <a class="btn btn-outline-primary btn-sm" href="/admin/technicians">Technicians</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/email-recipients">Email Recipients</a>
        <a class="btn btn-outline-info btn-sm" href="/admin/activity-logs">Activity Logs</a>
        <a class="btn btn-outline-warning btn-sm" href="/admin/backups">Backups</a>

        <form method="POST" action="/admin/logout">
          <button class="btn btn-outline-danger btn-sm">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <h4 class="mb-3">PPT Footer Settings</h4>

    <% if (message) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <form method="POST" action="/admin/ppt-settings">
          <div class="mb-3">
            <label class="form-label">Project Name</label>
            <input
              class="form-control"
              name="projectName"
              value="<%= settings.projectName || '' %>"
              placeholder="Enter project name"
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Contract / Project Code</label>
            <input
              class="form-control"
              name="projectCode"
              value="<%= settings.projectCode || '' %>"
              placeholder="Enter contract/project code"
            />
          </div>

          <hr />

          <div class="form-check form-switch mb-2">
            <input
              class="form-check-input"
              type="checkbox"
              name="showFooter"
              <%= settings.showFooter ? 'checked' : '' %>
            />
            <label class="form-check-label">Show Footer</label>
          </div>

          <div class="form-check form-switch mb-2">
            <input
              class="form-check-input"
              type="checkbox"
              name="showProjectName"
              <%= settings.showProjectName ? 'checked' : '' %>
            />
            <label class="form-check-label">Show Project Name</label>
          </div>

          <div class="form-check form-switch mb-2">
            <input
              class="form-check-input"
              type="checkbox"
              name="showProjectCode"
              <%= settings.showProjectCode ? 'checked' : '' %>
            />
            <label class="form-check-label">Show Contract / Project Code</label>
          </div>

          <div class="form-check form-switch mb-2">
            <input
              class="form-check-input"
              type="checkbox"
              name="showWorkOrderNumber"
              <%= settings.showWorkOrderNumber ? 'checked' : '' %>
            />
            <label class="form-check-label">Show Work Order Number</label>
          </div>

          <div class="form-check form-switch mb-4">
            <input
              class="form-check-input"
              type="checkbox"
              name="showPageNumber"
              <%= settings.showPageNumber ? 'checked' : '' %>
            />
            <label class="form-check-label">Show Page Number</label>
          </div>

          <button class="btn btn-primary" type="submit">
            Save PPT Settings
          </button>
        </form>
      </div>
    </div>

    <div class="card border-0 shadow-sm mt-4">
      <div class="card-body">
        <h6>Photo Layout Rules</h6>
        <ul class="mb-0">
          <li>Maximum 3 photos per page.</li>
          <li>If 3 photos are available, they use 3 equal slots.</li>
          <li>If 2 photos are left, they use 50% / 50% layout.</li>
          <li>If 1 photo is left, it uses the full photo area.</li>
          <li>Header logos and selected footer fields remain visible.</li>
          <li>Page number format is: Page Number: 1 of 7.</li>
        </ul>
      </div>
    </div>
  </main>
</body>
</html>
<!doctype html>
<html>
<head>
  <title>Email Recipients - Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/admin">Work Order Admin</a>
      <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" href="/admin">Dashboard</a>
        <a class="btn btn-outline-success btn-sm" href="/admin/work-orders">Work Orders</a>
        <a class="btn btn-outline-primary btn-sm" href="/admin/technicians">Technicians</a>
        <a class="btn btn-outline-info btn-sm" href="/admin/activity-logs">Activity Logs</a>
        <a class="btn btn-outline-warning btn-sm" href="/admin/backups">Backups</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/ppt-settings">PPT Settings</a>
        <form method="POST" action="/admin/logout">
          <button class="btn btn-outline-danger btn-sm">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <h4 class="mb-3">Email Recipients</h4>

    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-bold">Add Recipient</div>
      <div class="card-body">
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form method="POST" action="/admin/email-recipients" class="row g-2">
          <div class="col-md-4">
            <input class="form-control" name="name" placeholder="Recipient Name Optional" />
          </div>

          <div class="col-md-5">
            <input class="form-control" type="email" name="email" placeholder="recipient@example.com" required />
          </div>

          <div class="col-md-3">
            <button class="btn btn-primary w-100" type="submit">Add Email</button>
          </div>
        </form>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white fw-bold">Saved Recipients</div>
      <div class="card-body">
        <% if (recipients.length === 0) { %>
          <p class="text-muted mb-0">No email recipients added yet.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Status</th>
                  <th>Created</th>
                  <th>Action</th>
                </tr>
              </thead>

              <tbody>
                <% recipients.forEach(function(recipient) { %>
                  <tr>
                    <td><%= recipient.name || '-' %></td>
                    <td><%= recipient.email %></td>
                    <td>
                      <% if (recipient.is_active === 1) { %>
                        <span class="badge bg-success">Active</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Inactive</span>
                      <% } %>
                    </td>
                    <td><small><%= recipient.created_at %></small></td>
                    <td>
                      <div class="d-flex gap-2">
                        <form method="POST" action="/admin/email-recipients/<%= recipient.id %>/toggle">
                          <button class="btn btn-sm btn-outline-warning" type="submit">
                            <%= recipient.is_active === 1 ? 'Deactivate' : 'Activate' %>
                          </button>
                        </form>

                        <form
                          method="POST"
                          action="/admin/email-recipients/<%= recipient.id %>/delete"
                          onsubmit="return confirm('Delete this recipient?');"
                        >
                          <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
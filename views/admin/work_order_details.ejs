<!doctype html>
<html>
<head>
  <title>Work Order Details - Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <style>
    .photo-card img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      border-radius: 10px;
      background: #f1f1f1;
    }
  </style>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/admin">Work Order Admin</a>
      <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" href="/admin/work-orders">Work Orders</a>
        <a class="btn btn-outline-primary btn-sm" href="/admin/technicians">Technicians</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/email-recipients">Email Recipients</a>
        <a class="btn btn-outline-info btn-sm" href="/admin/activity-logs">Activity Logs</a>
        <a class="btn btn-outline-warning btn-sm" href="/admin/backups">Backups</a>
        <a class="btn btn-outline-dark btn-sm" href="/admin/ppt-settings">PPT Settings</a>
        <form method="POST" action="/admin/logout">
          <button class="btn btn-outline-danger btn-sm">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between flex-wrap gap-2">
          <div>
            <h4 class="mb-1">Work Order: <%= workOrder.work_order_number %></h4>
            <p class="text-muted mb-0">
              Asset ID: <%= workOrder.asset_id || '-' %>
            </p>
          </div>

          <div>
            <span class="badge bg-primary"><%= workOrder.status %></span>
            
            <div class="mt-3 d-flex gap-2 flex-wrap">
              <form method="POST" action="/admin/work-orders/<%= workOrder.id %>/generate-ppt">
                <button class="btn btn-success btn-sm" type="submit">
                  <%= workOrder.ppt_status === 'generated' ? 'Regenerate PPT' : 'Generate PPT' %>
                </button>
              </form>

              <form method="POST" action="/admin/work-orders/<%= workOrder.id %>/generate-ppt-and-send-email">
                <button class="btn btn-warning btn-sm" type="submit">
                  Generate PPT + Send Email
                </button>
              </form>

              <% if (workOrder.ppt_status === 'generated' && workOrder.ppt_file_path) { %>
                <a
                  class="btn btn-outline-primary btn-sm"
                  href="/admin/work-orders/<%= workOrder.id %>/download-ppt"
                >
                  Download PPT
                </a>

                <form method="POST" action="/admin/work-orders/<%= workOrder.id %>/send-email">
                  <button class="btn btn-outline-success btn-sm" type="submit">
                    Send Email
                  </button>
                </form>
              <% } %>

              <form
                method="POST"
                action="/admin/work-orders/<%= workOrder.id %>/delete"
                onsubmit="return confirm('Are you sure you want to delete this complete work order? This action cannot be undone.');"
              >
                <button class="btn btn-outline-danger btn-sm" type="submit">
                  Delete Work Order
                </button>
              </form>
            </div>
            
            <div class="mt-2">
              <% if (workOrder.ppt_status === 'needs_regeneration') { %>
                <span class="badge bg-warning text-dark">PPT needs regeneration</span>
              <% } else { %>
                <span class="badge bg-secondary"><%= workOrder.ppt_status || 'not_generated' %></span>
              <% } %>
            </div>

            <% if (workOrder.email_status === 'sent') { %>
              <span class="badge bg-success mt-2">Email Sent</span>
            <% } else if (workOrder.email_status === 'test_mode') { %>
              <span class="badge bg-info text-dark mt-2">Email Test Mode</span>
            <% } else if (workOrder.email_status === 'failed') { %>
              <span class="badge bg-danger mt-2">Email Failed</span>
            <% } else if (workOrder.email_status === 'sending') { %>
              <span class="badge bg-primary mt-2">Email Sending</span>
            <% } else { %>
              <span class="badge bg-secondary mt-2">Email Not Sent</span>
            <% } %>
          </div>
        </div>

        <hr />

        <div class="row g-3">
          <div class="col-md-4">
            <strong>Technician</strong><br />
            <%= workOrder.technician_name || 'Unknown' %><br />
            <small class="text-muted"><%= workOrder.technician_phone || '' %></small>
          </div>

          <div class="col-md-4">
            <strong>Submitted At</strong><br />
            <%= workOrder.submitted_at || '-' %>
          </div>

          <div class="col-md-4">
            <strong>Notes</strong><br />
            <%= workOrder.notes || '-' %>
          </div>
        </div>
      </div>
    </div>

    <% if (workOrder.email_sent_at || workOrder.email_error) { %>
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white fw-bold">Email Status</div>
        <div class="card-body">
          <p class="mb-1">
            <strong>Status:</strong>
            <%= workOrder.email_status || 'not_sent' %>
          </p>

          <% if (workOrder.email_sent_at) { %>
            <p class="mb-1">
              <strong>Time:</strong>
              <%= workOrder.email_sent_at %>
            </p>
          <% } %>

          <% if (workOrder.email_error) { %>
            <p class="mb-0 text-danger">
              <strong>Message:</strong>
              <%= workOrder.email_error %>
            </p>
          <% } %>
        </div>
      </div>
    <% } %>

    <% const stages = ['Before', 'During', 'After', 'Progress', 'Other']; %>

    <% stages.forEach(function(stage) { %>
      <div class="mb-4">
        <h5 class="mb-3"><%= stage %> Photos (<%= groupedPhotos[stage].length %>)</h5>

        <% if (groupedPhotos[stage].length === 0) { %>
          <div class="alert alert-light border">No <%= stage %> photos.</div>
        <% } else { %>
          <div class="row g-3">
            <% groupedPhotos[stage].forEach(function(photo) { %>
              <div class="col-md-4">
                <div class="card border-0 shadow-sm photo-card">
                  <div class="card-body">
                    <a href="<%= photo.url %>" target="_blank">
                      <img src="<%= photo.url %>" alt="<%= photo.stage %> photo" />
                    </a>

                    <div class="mt-3">
                      <div><strong>Stage:</strong> <%= photo.stage %></div>
                      <div><strong>Time:</strong> <%= photo.display_time || '-' %></div>
                      <div><strong>GPS:</strong> <%= photo.latitude || '-' %>, <%= photo.longitude || '-' %></div>
                    </div>

                    <form
                      method="POST"
                      action="/admin/work-orders/<%= workOrder.id %>/photos/<%= photo.id %>/delete"
                      class="mt-3"
                      onsubmit="return confirm('Delete this photo? This cannot be undone.');"
                    >
                      <button class="btn btn-sm btn-outline-danger w-100" type="submit">
                        Remove Bad Photo
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% }) %>
  </main>
</body>
</html>